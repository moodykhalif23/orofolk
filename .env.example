DATABASE_URL=postgres://b2b:b2b@localhost:5432/b2b?sslmode=disable

# JWT signing secret. Use >= 32 random bytes in production.
JWT_SECRET=change-me-in-production-please-32-bytes-min

# Access-token lifetime (Go duration).
JWT_TTL=24h

# HTTP listen port for the API.
HTTP_PORT=8080

# Environment + log level.
ENV=development
LOG_LEVEL=info
