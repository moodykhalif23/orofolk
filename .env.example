# Teggo environment template. Copy to .env and fill in real values.
# .env is git-ignored and must never be committed.

# ---- Postgres (compose) ----------------------------------------------------
POSTGRES_USER=teggo
POSTGRES_PASSWORD=change-me-in-.env
POSTGRES_DB=teggo

# ---- API / worker (required) ----------------------------------------------
# DATABASE_URL is assembled from the POSTGRES_* vars inside docker-compose;
# set it directly only when running the binaries outside compose.
# DATABASE_URL=postgres://teggo:change-me@localhost:5432/teggo?sslmode=disable

# 32+ byte random secret. Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_TTL=24h

# ---- Runtime --------------------------------------------------------------
ENV=development            # development | production (production => JSON logs)
LOG_LEVEL=info             # debug | info | warn | error
HTTP_PORT=8080

# Connection pool tuning (optional; defaults shown).
DB_MAX_CONNS=20
DB_MAX_CONN_IDLE_TIME=5m

# ---- Payments -------------------------------------------------------------
PAYMENTS_GATEWAY=mock      # mock (built-in) | stripe | mpesa (adapters pending)

# ---- Invoice PDF (worker) -------------------------------------------------
# Set in compose to http://gotenberg:3000; empty falls back to a stub renderer.
# GOTENBERG_URL=

# ---- Transactional email (worker) -----------------------------------------
# Leave SMTP_HOST empty to use the log transport (prints emails, sends nothing).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=Teggo <no-reply@teggo.local>
