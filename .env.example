# Copy to .env and adjust. .env is git-ignored and must never be committed.
# Docker Compose substitutes the values below; it has no credentials of its own.

# --- Postgres ---
# Used by Compose to provision the database and to build the in-network
# DATABASE_URL the containers use (host = the `postgres` service).
POSTGRES_USER=b2b
POSTGRES_PASSWORD=b2b
POSTGRES_DB=b2b

# --- App secret (CHANGE for any real deployment; min 32 bytes) ---
JWT_SECRET=change-me-in-production-please-32-bytes-min
JWT_TTL=24h

# --- API (host-run defaults) ---
HTTP_PORT=8080
ENV=development
LOG_LEVEL=info

# --- Gotenberg PDF service ---
# This value is for running the worker on the host. The Compose worker overrides
# it to http://gotenberg:3000 (the in-network service). Unset → stub PDF renderer.
GOTENBERG_URL=http://localhost:3000

# --- DATABASE_URL for host-run processes (make run-api / make run-worker) ---
# Points at the Postgres that Compose publishes on localhost:5432. Compose itself
# does NOT use this — it builds its own URL from the POSTGRES_* values above.
DATABASE_URL=postgres://b2b:b2b@localhost:5432/b2b?sslmode=disable
