# Copy to .env and fill in the secrets:   cp .env.example .env
# .env is gitignored — never commit real secrets.
DATABASE_URL=postgres://b2b:b2b@localhost:5432/b2b?sslmode=disable
POSTGRES_USER=b2b
POSTGRES_PASSWORD=b2b
POSTGRES_DB=b2b

# Auth
# Generate a strong secret:   openssl rand -base64 32
JWT_SECRET=
JWT_TTL=24h

# API
HTTP_PORT=8080
ENV=development
LOG_LEVEL=info

#  Observability (OpenTelemetry; optional) 
OTEL_EXPORTER_OTLP_ENDPOINT=

# PDF rendering (Gotenberg) 
# In Docker Compose this is set to http://gotenberg:3000 automatically.
GOTENBERG_URL=http://localhost:3000

# Transactional email (SMTP; optional — leave blank to disable sending) 
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=Teggo <no-reply@teggo.local>

# Payments
# mock = no real gateway (dev default).
PAYMENTS_GATEWAY=mock

# Real-time notifications (Pusher; optional)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# Multi-tenant / signup 
PLATFORM_BASE_DOMAIN=teggo.local
SIGNUP_VERIFY_URL=http://localhost:5173/verify-signup

# Per-tenant config encryption (secrets at rest; optional) 
# Generate:   openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=

#  AI assistant (optional) 
AI_PROVIDER=openai
AI_CHAT_BASE_URL=https://api.groq.com/openai/v1
AI_CHAT_MODEL=llama-3.3-70b-versatile
AI_CHAT_API_KEY=
